<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Panier</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <header>
    <h1>Simple E-commerce Store</h1>

    <nav>
  <a href="/">Accueil</a>
  <a href="/products">Produits</a>
  <a href="/cart">Panier (<%= cartCount %>)</a>

  <% if (user) { %>
    <span class="user-name">Bonjour <%= user.name %></span>
    <a href="/logout">Logout</a>
  <% } else { %>
    <a href="/login">Login</a>
    <a href="/register">Register</a>
  <% } %>
</nav>
  </header>

  <main>
    <section class="cart-container">
      <h2>Mon panier</h2>

      <% if (cart.length === 0) { %>

        <p class="empty-cart">Votre panier est vide.</p>
        <a class="btn-small" href="/products">Voir les produits</a>

      <% } else { %>

        <table class="cart-table">
          <thead>
            <tr>
              <th>Produit</th>
              <th>Prix</th>
              <th>Quantité</th>
              <th>Total</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody>
            <% cart.forEach(function(item) { %>
              <tr>
                <td class="cart-product">
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                  <span><%= item.name %></span>
                </td>

                <td><%= item.price %> DH</td>
                <td><%= item.quantity %></td>
                <td><%= item.price * item.quantity %> DH</td>

                <td>
                  <form action="/cart/remove/<%= item.id %>" method="POST">
                    <button class="btn-delete" type="submit">Supprimer</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="cart-total">
          <h3>Total général : <%= total %> DH</h3>
          <a href="/checkout" class="btn">Passer la commande</a>
        </div>

      <% } %>

    </section>
  </main>

</body>
</html>