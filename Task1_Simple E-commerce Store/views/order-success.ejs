<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Commande confirmée</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <header>
    <h1>Simple E-commerce Store</h1>

    <nav>
      <a href="/">Accueil</a>
      <a href="/products">Produits</a>
      <a href="/cart">Panier (<%= cartCount %>)</a>

      <% if (user) { %>
        <a href="/orders">Mes commandes</a>
        <span class="user-name">Bonjour <%= user.name %></span>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
  </header>

  <main>
    <section class="success-container">
      <h2>Commande confirmée</h2>

      <p>Merci <strong><%= order.userName %></strong>. Votre commande a été enregistrée avec succès.</p>

      <div class="order-box">
        <p><strong>Numéro de commande :</strong> #<%= order.id %></p>
        <p><strong>Date :</strong> <%= order.date %></p>
        <p><strong>Total :</strong> <%= order.total %> DH</p>
        <p><strong>Status :</strong> <%= order.status %></p>
        <p><strong>Paiement :</strong> <%= order.paymentMethod %></p>
      </div>

      <a href="/orders" class="btn">Voir mes commandes</a>
      <a href="/products" class="btn-small">Continuer les achats</a>
    </section>
  </main>

</body>
</html>